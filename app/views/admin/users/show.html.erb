<% content_for :title, "#{@user.full_name} - Admin" %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-8">
    <nav class="flex" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <%= link_to admin_root_path, class: "text-gray-400 hover:text-gray-500" do %>
            <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 00-1.414 1.414L2.586 12H9a2 2 0 012 2v7a2 2 0 01-2 2H2a2 2 0 01-2-2V7.414A2 2 0 01.586 6l7-7a2 2 0 012.828 0l7 7A2 2 0 0118 7.414V21a2 2 0 01-2 2h-7a2 2 0 01-2-2v-7a2 2 0 012-2h6.414L7.414 4 10.707 2.293z" />
            </svg>
            <span class="sr-only">Admin</span>
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to "Users", admin_users_path, class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-500"><%= @user.full_name %></span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="mt-4 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900"><%= @user.full_name %></h1>
        <p class="mt-2 text-gray-600"><%= @user.email %></p>
      </div>
      <div class="flex space-x-3">
        <%= link_to "Edit User", edit_admin_user_path(@user),
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        <% unless @user == current_user %>
          <%= link_to "Delete User", admin_user_path(@user),
              method: :delete,
              data: {
                "turbo-method": "delete",
                confirm: "Are you sure you want to delete this user? This action cannot be undone."
              },
              class: "inline-flex items-center px-4 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- User Information -->
    <div class="lg:col-span-1">
      <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">User Information</h2>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Name</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.full_name %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Email</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.email %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Handicap</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.handicap %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Role</dt>
            <dd class="mt-1">
              <% if @user.admin? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800">
                  Admin
                </span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                  Golfer
                </span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Member Since</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.created_at.strftime("%B %d, %Y") %></dd>
          </div>
        </div>
      </div>
    </div>

    <!-- Trip Assignments -->
    <div class="lg:col-span-2 space-y-8">
      <!-- Current Trips -->
      <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900">Trip Assignments</h2>
          <button type="button" onclick="document.getElementById('assign-trip-modal').classList.remove('hidden')"
              class="inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
            Assign to Trip
          </button>
        </div>
        <div class="p-6">
          <% if @user_trips.any? %>
            <div class="space-y-4">
              <% @user_trips.each do |trip| %>
                <div class="border border-gray-200 rounded-lg p-4">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <h3 class="text-sm font-semibold text-gray-900"><%= trip.name %></h3>
                      <p class="text-sm text-gray-500">
                        <%= trip.location %> •
                        <%= trip.start_date.strftime("%b %d") %> - <%= trip.end_date.strftime("%b %d, %Y") %>
                      </p>

                      <!-- Deposit Status -->
                      <% if trip.requires_deposit? %>
                        <% registration = @user.trip_registrations.find_by(trip: trip) %>
                        <div class="mt-2">
                          <span class="text-xs font-medium text-gray-500">Deposit ($<%= number_with_precision(trip.deposit_amount, precision: 2) %>):</span>
                          <% if registration&.deposit_paid? %>
                            <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                              Paid <%= registration.deposit_paid_date&.strftime("%m/%d") %>
                            </span>
                          <% else %>
                            <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">
                              Pending
                            </span>
                          <% end %>
                        </div>
                      <% end %>

                      <!-- Room Assignment for this trip -->
                      <% user_room = @user.room_for_trip(trip) %>
                      <div class="mt-2">
                        <% if user_room %>
                          <div class="flex items-center justify-between">
                            <div>
                              <span class="text-xs font-medium text-gray-500">Room:</span>
                              <span class="text-sm text-gray-900 ml-1"><%= user_room.name %></span>
                              <span class="text-xs text-gray-500 ml-1">
                                (<%= user_room.accommodation.name %>)
                              </span>
                            </div>
                            <button type="button"
                                onclick="showRoomModal(<%= trip.id %>)"
                                class="text-xs text-blue-600 hover:text-blue-900">
                              Change Room
                            </button>
                          </div>
                        <% else %>
                          <button type="button"
                              onclick="showRoomModal(<%= trip.id %>)"
                              class="inline-flex items-center px-2 py-1 border border-transparent text-xs font-medium rounded text-yellow-700 bg-yellow-100 hover:bg-yellow-200">
                            Assign Room
                          </button>
                        <% end %>
                      </div>
                    </div>
                    <div class="ml-4">
                      <%= link_to "Remove", remove_from_trip_admin_user_path(@user, trip_id: trip.id),
                          method: :delete,
                          data: { "turbo-method": "delete" },
                          class: "text-xs text-red-600 hover:text-red-900" %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">User is not registered for any trips.</p>
          <% end %>
        </div>
      </div>

      <!-- Room Reservations History -->
      <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">Room Reservation History</h2>
        </div>
        <div class="p-6">
          <% if @room_reservations.any? %>
            <div class="space-y-3">
              <% @room_reservations.each do |reservation| %>
                <div class="flex items-center justify-between text-sm">
                  <div>
                    <span class="font-medium text-gray-900"><%= reservation.room.name %></span>
                    <span class="text-gray-500 ml-2">
                      <%= reservation.room.accommodation.name %> - <%= reservation.room.accommodation.trip.name %>
                    </span>
                  </div>
                  <div class="text-xs text-gray-500">
                    <%= reservation.reservation_date.strftime("%b %d, %Y") %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">No room reservations yet.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Assign Trip Modal -->
<div id="assign-trip-modal" class="hidden fixed z-10 inset-0 overflow-y-auto">
  <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>
    <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
    <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
      <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Assign User to Trip</h3>
        <div class="mt-4">
          <% if @available_trips.any? %>
            <%= form_with url: assign_trip_admin_user_path(@user), method: :post, local: true do |f| %>
              <div class="mb-4">
                <%= f.select :trip_id,
                    options_for_select(@available_trips.map { |t| ["#{t.name} (#{t.start_date.strftime('%b %d, %Y')})", t.id] }),
                    { prompt: "Select a trip..." },
                    class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
              </div>
              <div class="flex justify-end space-x-3">
                <button type="button" onclick="document.getElementById('assign-trip-modal').classList.add('hidden')"
                    class="inline-flex justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                  Cancel
                </button>
                <%= f.submit "Assign to Trip",
                    class: "inline-flex justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500">User is already assigned to all available trips.</p>
            <div class="mt-4 flex justify-end">
              <button type="button" onclick="document.getElementById('assign-trip-modal').classList.add('hidden')"
                  class="inline-flex justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                Close
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Room Assignment Modals (generated dynamically) -->
<% @user_trips.each do |trip| %>
  <div id="room-modal-<%= trip.id %>" class="hidden fixed z-10 inset-0 overflow-y-auto">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
      <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>
      <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
      <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
        <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Select Room for <%= trip.name %></h3>
          <div class="mt-4">
            <%= form_with url: update_room_admin_user_path(@user), method: :post, local: true do |f| %>
              <div class="mb-4">
                <% trip.accommodations.each do |accommodation| %>
                  <div class="mb-3">
                    <h4 class="text-sm font-medium text-gray-700"><%= accommodation.name %></h4>
                    <%= f.select :room_id,
                        options_for_select(accommodation.rooms.map { |r| ["#{r.name} (#{r.available_spots}/#{r.capacity} available)", r.id] }),
                        { prompt: "Select a room..." },
                        class: "mt-1 appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
                  </div>
                <% end %>
              </div>
              <div class="flex justify-end space-x-3">
                <button type="button" onclick="hideRoomModal(<%= trip.id %>)"
                    class="inline-flex justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                  Cancel
                </button>
                <%= f.submit "Assign Room",
                    class: "inline-flex justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
function showRoomModal(tripId) {
  document.getElementById('room-modal-' + tripId).classList.remove('hidden');
}

function hideRoomModal(tripId) {
  document.getElementById('room-modal-' + tripId).classList.add('hidden');
}
</script>