<% content_for :title, "Accommodations for #{@trip.name} - Admin" %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-8">
    <nav class="flex" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <%= link_to admin_root_path, class: "text-gray-400 hover:text-gray-500" do %>
            <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 10.5v6.25A2.25 2.25 0 0114.75 19h-1.5A2.25 2.25 0 0111 16.75v-4.5A.75.75 0 0111.75 12h1.5a.75.75 0 01.75.75v4.5a.75.75 0 00.75.75h1.5a.75.75 0 00.75-.75V10.5a1 1 0 01.293-.707l7-7a1 1 0 011.414 1.414L10.707 11.5H16a1 1 0 010 2H9.707l6.586 6.586a1 1 0 11-1.414 1.414l-7-7A1 1 0 018.586 13H3a1 1 0 010-2h5.586L2 4.414A1 1 0 013.414 3l7 7z" clip-rule="evenodd" />
            </svg>
            <span class="sr-only">Admin</span>
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to "Trips", admin_trips_path, class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to @trip.name, admin_trip_path(@trip), class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-500">Accommodations</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="mt-4 md:flex md:items-center md:justify-between">
      <div class="min-w-0 flex-1">
        <h1 class="text-3xl font-bold text-gray-900">Accommodations</h1>
        <p class="mt-2 text-gray-600">Manage accommodations for <%= @trip.name %></p>
      </div>
      <div class="mt-4 flex md:ml-4 md:mt-0">
        <%= link_to "Add Accommodation", new_admin_trip_accommodation_path(@trip),
            class: "inline-flex items-center rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600" %>
      </div>
    </div>
  </div>

  <!-- Accommodations List -->
  <% if @accommodations.any? %>
    <div class="grid gap-6 sm:grid-cols-1 lg:grid-cols-2">
      <% @accommodations.each do |accommodation| %>
        <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold text-gray-900"><%= accommodation.name %></h3>
                <div class="mt-1 flex items-center space-x-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= accommodation.accommodation_type == 'hotel' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
                    <%= accommodation.accommodation_type.capitalize %>
                  </span>
                  <span class="text-sm text-gray-500">
                    <%= accommodation.rooms.count %> rooms
                  </span>
                </div>
              </div>
              <div class="text-right">
                <div class="text-lg font-semibold text-gray-900">
                  $<%= number_with_precision(accommodation.total_cost, precision: 2) %>
                </div>
                <div class="text-sm text-gray-500">total cost</div>
              </div>
            </div>
          </div>

          <div class="px-6 py-4">
            <div class="space-y-3">
              <div>
                <dt class="text-sm font-medium text-gray-500">Address</dt>
                <dd class="text-sm text-gray-900"><%= accommodation.address %></dd>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <dt class="text-sm font-medium text-gray-500">Check-in</dt>
                  <dd class="text-sm text-gray-900"><%= accommodation.check_in_date.strftime("%b %d, %Y") %></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Check-out</dt>
                  <dd class="text-sm text-gray-900"><%= accommodation.check_out_date.strftime("%b %d, %Y") %></dd>
                </div>
              </div>

              <% if accommodation.description.present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Description</dt>
                  <dd class="text-sm text-gray-900"><%= truncate(accommodation.description, length: 150) %></dd>
                </div>
              <% end %>

              <!-- Room Summary -->
              <div class="pt-3 border-t border-gray-200">
                <div class="flex items-center justify-between">
                  <div class="text-sm text-gray-500">
                    <span class="font-medium"><%= accommodation.rooms.sum(:capacity) %></span> total capacity
                    •
                    <span class="font-medium"><%= accommodation.rooms.joins(:room_reservations).count %></span> reservations
                  </div>
                  <div class="text-sm">
                    <%= link_to "Manage Rooms", admin_trip_accommodation_rooms_path(@trip, accommodation),
                        class: "text-green-600 hover:text-green-900 font-medium" %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-between">
            <div class="space-x-3">
              <%= link_to "View Details", admin_trip_accommodation_path(@trip, accommodation),
                  class: "text-green-600 hover:text-green-900 text-sm font-medium" %>
              <%= link_to "Edit", edit_admin_trip_accommodation_path(@trip, accommodation),
                  class: "text-blue-600 hover:text-blue-900 text-sm font-medium" %>
            </div>
            <div>
              <%= link_to "Delete", admin_trip_accommodation_path(@trip, accommodation),
                  method: :delete,
                  class: "text-red-600 hover:text-red-900 text-sm font-medium",
                  data: {
                    "turbo-method": "delete",
                    confirm: "Are you sure you want to delete this accommodation? This will remove all associated rooms and reservations."
                  } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-12 bg-white shadow-lg rounded-lg border border-gray-200">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-6m-2-5v5m2-5v5m-8-5v5m8-10V9a2 2 0 00-2-2H9a2 2 0 00-2 2v1m8 0V9a2 2 0 012 2v1M5 21h14" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No accommodations yet</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by adding your first accommodation for this trip.</p>
      <div class="mt-6">
        <%= link_to "Add Accommodation", new_admin_trip_accommodation_path(@trip),
            class: "inline-flex items-center rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600" %>
      </div>
    </div>
  <% end %>
</div>