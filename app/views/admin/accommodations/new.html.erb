<% content_for :title, "Add Accommodation to #{@trip.name} - Admin" %>

<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-8">
    <nav class="flex" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <%= link_to admin_root_path, class: "text-gray-400 hover:text-gray-500" do %>
            <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 10.5v6.25A2.25 2.25 0 0114.75 19h-1.5A2.25 2.25 0 0111 16.75v-4.5A.75.75 0 0111.75 12h1.5a.75.75 0 01.75.75v4.5a.75.75 0 00.75.75h1.5a.75.75 0 00.75-.75V10.5a1 1 0 01.293-.707l7-7a1 1 0 011.414 1.414L10.707 11.5H16a1 1 0 010 2H9.707l6.586 6.586a1 1 0 11-1.414 1.414l-7-7A1 1 0 018.586 13H3a1 1 0 010-2h5.586L2 4.414A1 1 0 013.414 3l7 7z" clip-rule="evenodd" />
            </svg>
            <span class="sr-only">Admin</span>
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to "Trips", admin_trips_path, class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to @trip.name, admin_trip_path(@trip), class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to "Accommodations", admin_trip_accommodations_path(@trip), class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-500">Add Accommodation</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="mt-4">
      <h1 class="text-3xl font-bold text-gray-900">Add Accommodation</h1>
      <p class="mt-2 text-gray-600">Add a hotel or house accommodation for <%= @trip.name %>. You'll be able to add rooms after creating the accommodation.</p>
    </div>
  </div>

  <!-- Form -->
  <div class="bg-white shadow-lg rounded-lg border border-gray-200">
    <%= form_with model: [:admin, @trip, @accommodation], local: true, class: "space-y-6" do |form| %>
      <div class="px-6 py-6">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <!-- Accommodation Name -->
          <div class="sm:col-span-2">
            <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :name,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "e.g., The Phoenician Resort or Scottsdale House" %>
            </div>
            <% if @accommodation.errors[:name].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @accommodation.errors[:name].first %></p>
            <% end %>
          </div>

          <!-- Accommodation Type -->
          <div>
            <%= form.label :accommodation_type, "Type", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.select :accommodation_type,
                  options_for_select([
                    ['Hotel', 'hotel'],
                    ['House', 'house']
                  ], @accommodation.accommodation_type),
                  { prompt: 'Select accommodation type' },
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
            </div>
            <% if @accommodation.errors[:accommodation_type].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @accommodation.errors[:accommodation_type].first %></p>
            <% end %>
          </div>

          <!-- Total Cost -->
          <div>
            <%= form.label :total_cost, "Total Cost ($)", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1 relative rounded-md shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-gray-500 sm:text-sm">$</span>
              </div>
              <%= form.number_field :total_cost,
                  step: 0.01,
                  class: "appearance-none block w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "0.00" %>
            </div>
            <p class="mt-1 text-xs text-gray-500">Total cost for the entire accommodation (all rooms combined)</p>
            <% if @accommodation.errors[:total_cost].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @accommodation.errors[:total_cost].first %></p>
            <% end %>
          </div>

          <!-- Address -->
          <div class="sm:col-span-2">
            <%= form.label :address, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_area :address,
                  rows: 2,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "Full address including city, state, and zip code" %>
            </div>
            <% if @accommodation.errors[:address].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @accommodation.errors[:address].first %></p>
            <% end %>
          </div>

          <!-- Check-in Date -->
          <div>
            <%= form.label :check_in_date, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.date_field :check_in_date,
                  value: @trip.start_date,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
            </div>
            <% if @accommodation.errors[:check_in_date].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @accommodation.errors[:check_in_date].first %></p>
            <% end %>
          </div>

          <!-- Check-out Date -->
          <div>
            <%= form.label :check_out_date, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.date_field :check_out_date,
                  value: @trip.end_date,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
            </div>
            <% if @accommodation.errors[:check_out_date].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @accommodation.errors[:check_out_date].first %></p>
            <% end %>
          </div>

          <!-- Description -->
          <div class="sm:col-span-2">
            <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_area :description,
                  rows: 4,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "Describe the accommodation, amenities, and any special features..." %>
            </div>
            <% if @accommodation.errors[:description].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @accommodation.errors[:description].first %></p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-end space-x-3">
        <%= link_to "Cancel", admin_trip_accommodations_path(@trip),
            class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        <%= form.submit "Create Accommodation",
            class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
      </div>
    <% end %>
  </div>
</div>