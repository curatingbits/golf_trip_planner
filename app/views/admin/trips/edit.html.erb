<% content_for :title, "Edit #{@trip.name} - Admin" %>

<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-8">
    <nav class="flex" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <%= link_to admin_root_path, class: "text-gray-400 hover:text-gray-500" do %>
            <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 10.5v6.25A2.25 2.25 0 0114.75 19h-1.5A2.25 2.25 0 0111 16.75v-4.5A.75.75 0 0111.75 12h1.5a.75.75 0 01.75.75v4.5a.75.75 0 00.75.75h1.5a.75.75 0 00.75-.75V10.5a1 1 0 01.293-.707l7-7a1 1 0 011.414 1.414L10.707 11.5H16a1 1 0 010 2H9.707l6.586 6.586a1 1 0 11-1.414 1.414l-7-7A1 1 0 018.586 13H3a1 1 0 010-2h5.586L2 4.414A1 1 0 013.414 3l7 7z" clip-rule="evenodd" />
            </svg>
            <span class="sr-only">Admin</span>
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to "Trips", admin_trips_path, class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to @trip.name, admin_trip_path(@trip), class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-500">Edit</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="mt-4">
      <h1 class="text-3xl font-bold text-gray-900">Edit Trip</h1>
      <p class="mt-2 text-gray-600">Update trip information, dates, and settings.</p>
    </div>
  </div>

  <!-- Form -->
  <div class="bg-white shadow-lg rounded-lg border border-gray-200">
    <%= form_with model: [:admin, @trip], local: true, multipart: true, class: "space-y-6" do |form| %>
      <div class="px-6 py-6">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <!-- Trip Name -->
          <div class="sm:col-span-2">
            <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :name,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "e.g., Scottsdale Golf Trip 2026" %>
            </div>
            <% if @trip.errors[:name].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:name].first %></p>
            <% end %>
          </div>

          <!-- Location -->
          <div>
            <%= form.label :location, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :location,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "e.g., Scottsdale, Arizona" %>
            </div>
            <% if @trip.errors[:location].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:location].first %></p>
            <% end %>
          </div>

          <!-- Total Cost -->
          <div>
            <%= form.label :total_cost, "Total Cost ($)", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1 relative rounded-md shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-gray-500 sm:text-sm">$</span>
              </div>
              <%= form.number_field :total_cost,
                  step: 0.01,
                  class: "appearance-none block w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "0.00" %>
            </div>
            <% if @trip.errors[:total_cost].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:total_cost].first %></p>
            <% end %>
          </div>

          <!-- Deposit Amount -->
          <div>
            <%= form.label :deposit_amount, "Deposit Amount ($)", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1 relative rounded-md shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-gray-500 sm:text-sm">$</span>
              </div>
              <%= form.number_field :deposit_amount,
                  step: 0.01,
                  class: "appearance-none block w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "0.00" %>
            </div>
            <p class="mt-1 text-xs text-gray-500">Leave blank or 0 if no deposit required</p>
            <% if @trip.errors[:deposit_amount].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:deposit_amount].first %></p>
            <% end %>
          </div>

          <!-- Start Date -->
          <div>
            <%= form.label :start_date, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.date_field :start_date,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
            </div>
            <% if @trip.errors[:start_date].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:start_date].first %></p>
            <% end %>
          </div>

          <!-- End Date -->
          <div>
            <%= form.label :end_date, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.date_field :end_date,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" %>
            </div>
            <% if @trip.errors[:end_date].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:end_date].first %></p>
            <% end %>
          </div>

          <!-- Description -->
          <div class="sm:col-span-2">
            <div class="flex justify-between items-center">
              <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
              <span class="text-xs text-gray-500">Supports Markdown formatting</span>
            </div>
            <div class="mt-1">
              <%= form.text_area :description,
                  rows: 4,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  placeholder: "Describe the trip, activities, and what makes it special..." %>
            </div>
            <div class="mt-2 text-xs text-gray-500">
              <p class="font-semibold mb-1">Markdown formatting tips:</p>
              <ul class="space-y-1">
                <li>• <strong>**Bold text**</strong> for emphasis</li>
                <li>• <em>*Italic text*</em> for subtle emphasis</li>
                <li>• # Heading (use ## for smaller headings)</li>
                <li>• - or * for bullet points</li>
                <li>• 1. 2. 3. for numbered lists</li>
                <li>• [Link text](https://example.com) for links</li>
              </ul>
            </div>
            <% if @trip.errors[:description].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:description].first %></p>
            <% end %>
          </div>

          <!-- File Attachments -->
          <div class="sm:col-span-2">
            <%= form.label :attachments, "Attachments", class: "block text-sm font-medium text-gray-700" %>
            <% if @trip.attachments.any? %>
              <div class="mt-2 space-y-2">
                <% @trip.attachments.each do |attachment| %>
                  <div class="flex items-center justify-between p-2 bg-gray-50 rounded-md">
                    <div class="flex items-center text-sm text-gray-700">
                      <% if attachment.content_type == "application/pdf" %>
                        <svg class="h-5 w-5 text-red-500 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                      <% elsif attachment.content_type.start_with?("image/") %>
                        <svg class="h-5 w-5 text-blue-500 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                        </svg>
                      <% else %>
                        <svg class="h-5 w-5 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M12 12v-1.5c0-.621-.504-1.125-1.125-1.125M12 12c0-.621.504-1.125 1.125-1.125m-2.25 0c-.621 0-1.125-.504-1.125-1.125M12 12c.621 0 1.125-.504 1.125-1.125m0 0v-1.5c0-.621.504-1.125 1.125-1.125m-2.25 0c.621 0 1.125.504 1.125 1.125" />
                        </svg>
                      <% end %>
                      <%= attachment.filename %>
                    </div>
                    <%= link_to remove_attachment_admin_trip_path(@trip, attachment_id: attachment.id),
                        method: :delete,
                        data: { "turbo-method": "delete", confirm: "Remove this attachment?" },
                        class: "text-red-600 hover:text-red-800 text-sm font-medium" do %>
                      Remove
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
            <div class="mt-2">
              <%= form.file_field :attachments,
                  multiple: true,
                  accept: ".pdf,.jpg,.jpeg,.png,.csv",
                  class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-green-50 file:text-green-700 hover:file:bg-green-100" %>
            </div>
            <p class="mt-1 text-xs text-gray-500">PDF, JPG, PNG, or CSV files up to 10MB each. New files are added to existing attachments.</p>
            <% if @trip.errors[:attachments].any? %>
              <p class="mt-2 text-sm text-red-600"><%= @trip.errors[:attachments].first %></p>
            <% end %>
          </div>

          <!-- Active Status -->
          <div class="sm:col-span-2">
            <div class="flex items-start">
              <div class="flex items-center h-5">
                <%= form.check_box :active,
                    class: "focus:ring-green-500 h-4 w-4 text-green-600 border-gray-300 rounded" %>
              </div>
              <div class="ml-3 text-sm">
                <%= form.label :active, "Active Trip", class: "font-medium text-gray-700" %>
                <p class="text-gray-500">Make this trip visible and available for user registration</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-between">
        <div>
          <%= link_to "Cancel", admin_trip_path(@trip),
              class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        </div>
        <div class="space-x-3">
          <%= link_to "Delete Trip", admin_trip_path(@trip),
              method: :delete,
              class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500",
              data: {
                "turbo-method": "delete",
                confirm: "Are you sure you want to delete this trip? This action cannot be undone and will remove all associated data."
              } %>
          <%= form.submit "Update Trip",
              class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
