<% content_for :title, "#{@trip.name} - Okie Cup" %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <!-- Trip Header -->
  <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden mb-8">
    <div class="px-6 py-8">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
        <div class="flex-1">
          <h1 class="text-3xl font-bold text-gray-900"><%= @trip.name %></h1>
          <div class="mt-4 flex flex-col sm:flex-row sm:items-center text-sm text-gray-500 space-y-2 sm:space-y-0 sm:space-x-6">
            <div class="flex items-center">
              <svg class="mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <%= @trip.location %>
            </div>
            <div class="flex items-center">
              <svg class="mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5a2.25 2.25 0 002.25-2.25m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5a2.25 2.25 0 012.25 2.25v7.5m-18 0h18" />
              </svg>
              <%= @trip.start_date.strftime("%B %d") %> - <%= @trip.end_date.strftime("%B %d, %Y") %>
            </div>
            <div class="flex items-center">
              <svg class="mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <%= @trip.duration_days %> days
            </div>
          </div>
          <div class="mt-4 text-gray-600 markdown-content"><%= render_markdown(@trip.description).html_safe %></div>
        </div>
        <div class="flex-shrink-0 lg:ml-6 flex flex-col space-y-3">
          <% if current_user&.registered_for_trip?(@trip) %>
            <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-green-100 text-green-800">
              <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Registered
            </span>

            <!-- Deposit Status -->
            <% if @trip.requires_deposit? %>
              <% registration = current_user.trip_registrations.find_by(trip: @trip) %>
              <div class="text-right">
                <% if registration&.deposit_paid? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                    </svg>
                    Deposit Paid
                  </span>
                  <% if registration.deposit_paid_date.present? %>
                    <p class="text-xs text-gray-500 mt-1">
                      Paid on <%= registration.deposit_paid_date&.strftime("%B %d, %Y") || "Unknown date" %>
                    </p>
                  <% end %>
                <% else %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                    <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    Deposit Required
                  </span>
                  <p class="text-sm font-semibold text-gray-700 mt-1">
                    Amount: $<%= number_with_precision(@trip.deposit_amount, precision: 2) %>
                  </p>
                  <p class="text-xs text-gray-500 mt-1">
                    Contact admin to confirm payment
                  </p>
                <% end %>
              </div>
            <% end %>
            <% if @user_room %>
              <div class="text-sm text-gray-600 text-right">
                <span class="font-medium">Room:</span> <%= @user_room.name %>
                <div class="text-xs text-gray-500">$<%= number_with_precision(@user_room.cost_per_person, precision: 2) %> per person</div>
                <% if @user_room.current_occupants.size > 1 %>
                  <div class="mt-1 text-xs text-gray-500">
                    <span class="font-medium">Roommates:</span>
                    <% @user_room.current_occupants.reject { |o| o == current_user }.each do |roommate| %>
                      <span class="inline-block"><%= roommate.full_name %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="flex flex-col sm:flex-row gap-3">
                <%= link_to "Change Room", room_selection_trip_path(@trip),
                    class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
                <%= link_to "View All Registered Users", registered_users_trip_path(@trip),
                    class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              </div>
            <% else %>
              <div class="flex flex-col sm:flex-row gap-3">
                <%= link_to "Select Room", room_selection_trip_path(@trip),
                    class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-yellow-600 hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500" %>
                <%= link_to "View All Registered Users", registered_users_trip_path(@trip),
                    class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              </div>
            <% end %>
          <% elsif current_user %>
            <!-- Registration button for logged-in users who aren't registered -->
            <%= form_with url: register_trip_path(@trip), method: :post, local: true, class: "inline" do |f| %>
              <%= f.submit "Register for Trip", class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 shadow-lg transform transition hover:scale-105" %>
            <% end %>
            <p class="text-sm text-gray-600 mt-2 text-right max-w-xs">
              Register now to secure your spot and select your room!
            </p>
          <% else %>
            <!-- Login prompt for non-authenticated users -->
            <div class="text-center">
              <%= link_to "Login to Register", login_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 shadow-lg" %>
              <p class="text-sm text-gray-600 mt-2">
                Login to register for this trip
              </p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Golf Schedule -->
    <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900 flex items-center">
          <svg class="mr-2 h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
          </svg>
          Golf Schedule
        </h2>
      </div>
      <div class="p-6">
        <% if @golf_rounds.any? %>
          <div class="space-y-4">
            <% @golf_rounds.each do |round| %>
              <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                <div>
                  <h3 class="font-semibold text-gray-900"><%= round.course&.name || round.course_name %></h3>
                  <p class="text-sm text-gray-500">
                    <% if round.tee_time %>
                      <%= round.tee_time&.strftime("%A, %B %d at %I:%M %p") || "Time TBD" %>
                    <% end %>
                  </p>
                </div>
                <div class="text-right">
                  <div class="text-lg font-bold text-green-600">$<%= number_with_precision(round.cost_per_person, precision: 0) %></div>
                  <div class="text-xs text-gray-500">per person</div>
                </div>
              </div>
            <% end %>
          </div>
          <div class="mt-6 pt-4 border-t border-gray-200">
            <div class="flex justify-between items-center font-semibold">
              <span>Total Golf Cost:</span>
              <span class="text-xl text-green-600">$<%= number_with_precision(@golf_rounds.sum(:cost_per_person), precision: 0) %></span>
            </div>
          </div>
        <% else %>
          <p class="text-gray-500 text-center py-8">No golf rounds scheduled yet.</p>
        <% end %>
      </div>
    </div>

    <!-- Betting Pools -->
    <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900 flex items-center">
          <svg class="mr-2 h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Betting Pools
        </h2>
      </div>
      <div class="p-6">
        <% if @betting_pools.any? %>
          <div class="space-y-4">
            <% @betting_pools.each do |pool| %>
              <div class="p-4 bg-gray-50 rounded-lg">
                <div class="flex justify-between items-start">
                  <div class="flex-1">
                    <h3 class="font-semibold text-gray-900"><%= pool.name %></h3>
                    <p class="text-sm text-gray-600 mt-1"><%= pool.description %></p>
                  </div>
                  <div class="text-right ml-4">
                    <div class="text-lg font-bold text-blue-600">$<%= number_with_precision(pool.entry_fee || pool.cost_per_person, precision: 0) %></div>
                    <div class="text-xs text-gray-500">per person</div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          <div class="mt-6 pt-4 border-t border-gray-200">
            <div class="flex justify-between items-center font-semibold">
              <span>Total Betting Cost:</span>
              <span class="text-xl text-blue-600">$<%= number_with_precision(@betting_pools.sum(:cost_per_person), precision: 0) %></span>
            </div>
          </div>
        <% else %>
          <p class="text-gray-500 text-center py-8">No betting pools available.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Documents & Files -->
  <% if @trip.attachments.any? %>
    <div class="mt-8 bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900 flex items-center">
          <svg class="mr-2 h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
          Documents & Files
        </h2>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <% @trip.attachments.each do |attachment| %>
            <%= link_to rails_blob_path(attachment, disposition: "attachment"), class: "flex items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group" do %>
              <% if attachment.content_type == "application/pdf" %>
                <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-red-100 flex items-center justify-center">
                  <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                </div>
              <% elsif attachment.content_type.start_with?("image/") %>
                <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-blue-100 flex items-center justify-center">
                  <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                  </svg>
                </div>
              <% else %>
                <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-green-100 flex items-center justify-center">
                  <svg class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M12 12v-1.5c0-.621-.504-1.125-1.125-1.125M12 12c0-.621.504-1.125 1.125-1.125m-2.25 0c-.621 0-1.125-.504-1.125-1.125M12 12c.621 0 1.125-.504 1.125-1.125m0 0v-1.5c0-.621.504-1.125 1.125-1.125m-2.25 0c.621 0 1.125.504 1.125 1.125" />
                  </svg>
                </div>
              <% end %>
              <div class="ml-3 min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-900 truncate group-hover:text-green-700"><%= attachment.filename %></p>
                <p class="text-xs text-gray-500"><%= number_to_human_size(attachment.byte_size) %></p>
              </div>
              <svg class="ml-2 h-4 w-4 text-gray-400 group-hover:text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Accommodations -->
  <div class="mt-8 bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 flex items-center">
        <svg class="mr-2 h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m2.25-18v18m13.5-18v18m2.25-18v18M6.75 9h.75v.75h-.75V9zm0 3h.75v.75h-.75V12zm0 3h.75v.75h-.75V15zm3-6h.75v.75h-.75V9zm0 3h.75v.75h-.75V12zm0 3h.75v.75h-.75V15z" />
        </svg>
        Accommodations
      </h2>
    </div>
    <div class="p-6">
      <% @accommodations.each do |accommodation| %>
        <div class="mb-8 last:mb-0">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-semibold text-gray-900"><%= accommodation.name %></h3>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
              <%= accommodation.accommodation_type.titleize %>
            </span>
          </div>

          <% if accommodation.address.present? %>
            <p class="text-gray-600 mb-4"><%= accommodation.address %></p>
          <% end %>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% accommodation.rooms.each do |room| %>
              <div class="border border-gray-200 rounded-lg p-4 <%= @user_room == room ? 'ring-2 ring-green-500 bg-green-50' : 'hover:shadow-md transition-shadow' %>">
                <div class="flex justify-between items-start mb-2">
                  <h4 class="font-semibold text-gray-900"><%= room.name %></h4>
                  <% if @user_room == room %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Your Room
                    </span>
                  <% end %>
                </div>

                <% if room.description.present? %>
                  <p class="text-sm text-gray-600 mb-3"><%= room.description %></p>
                <% end %>

                <% if room.current_occupants.any? %>
                  <div class="mb-3">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Occupants</p>
                    <div class="space-y-1">
                      <% room.current_occupants.each do |occupant| %>
                        <div class="flex items-center text-sm">
                          <svg class="h-3 w-3 text-gray-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                          </svg>
                          <span class="text-gray-700"><%= occupant.full_name %></span>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <div class="flex justify-between items-center">
                  <div>
                    <div class="text-lg font-bold text-gray-900">$<%= number_with_precision(room.cost_per_person, precision: 2) %></div>
                    <div class="text-xs text-gray-500">per person</div>
                  </div>
                  <div class="text-right">
                    <div class="text-sm text-gray-600">Capacity: <%= room.capacity %></div>
                    <div class="text-xs text-gray-500">
                      <%= room.available_spots %> spot<%= room.available_spots == 1 ? '' : 's' %> available
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Cost Summary -->
  <div class="mt-8 bg-gradient-to-r from-green-50 to-blue-50 border border-gray-200 rounded-lg p-6">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Trip Cost Summary</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="text-center">
        <div class="text-2xl font-bold text-green-600">$<%= number_with_precision(@golf_rounds.sum(:cost_per_person), precision: 0) %></div>
        <div class="text-sm text-gray-600">Golf Rounds</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-blue-600">$<%= number_with_precision(@betting_pools.sum(:cost_per_person), precision: 0) %></div>
        <div class="text-sm text-gray-600">Betting Pools</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-purple-600">
          <% if @user_room %>
            $<%= number_with_precision(@user_room.cost_per_person, precision: 2) %>
          <% else %>
            TBD
          <% end %>
        </div>
        <div class="text-sm text-gray-600">Accommodation</div>
      </div>
    </div>
    <div class="mt-6 pt-4 border-t border-gray-300">
      <div class="text-center">
        <div class="text-3xl font-bold text-gray-900">
          <% if @user_room %>
            $<%= number_with_precision(@golf_rounds.sum(:cost_per_person) + @betting_pools.sum(:cost_per_person) + @user_room.cost_per_person, precision: 2) %>
          <% else %>
            $<%= number_with_precision(@golf_rounds.sum(:cost_per_person) + @betting_pools.sum(:cost_per_person), precision: 2) %>+
          <% end %>
        </div>
        <div class="text-sm text-gray-600">Total Trip Cost per Person</div>

        <% if @trip.requires_deposit? %>
          <% registration = current_user.trip_registrations.find_by(trip: @trip) if current_user.registered_for_trip?(@trip) %>
          <div class="mt-4 pt-4 border-t border-gray-200">
            <div class="inline-flex items-center justify-center space-x-2">
              <% if registration&.deposit_paid? %>
                <svg class="h-5 w-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm font-medium text-green-700">
                  Deposit of $<%= number_with_precision(@trip.deposit_amount, precision: 2) %> paid
                </span>
              <% else %>
                <svg class="h-5 w-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm font-medium text-yellow-700">
                  Deposit required: $<%= number_with_precision(@trip.deposit_amount, precision: 2) %>
                </span>
              <% end %>
            </div>
            <% if @trip.requires_deposit? && current_user.registered_for_trip?(@trip) %>
              <% registration = current_user.trip_registrations.find_by(trip: @trip) %>
              <% unless registration&.deposit_paid? %>
                <div class="mt-3 flex justify-center">
                  <a href="venmo://paycharge?txn=pay&recipients=drobsokc&amount=<%= @trip.deposit_amount %>&note=<%= URI.encode_www_form_component("#{@trip.name} deposit") %>"
                     class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-semibold bg-blue-600 text-white border border-blue-600 shadow-sm hover:bg-blue-700 transition-colors">
                    <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M13.454 9.046h-1.454v4.615c0 1.077-.769 1.846-1.846 1.846s-1.846-.769-1.846-1.846v-4.615h-1.454c-.308 0-.615-.308-.615-.615s.308-.615.615-.615h5.6c.308 0 .615.308.615.615s-.307.615-.615.615zm-2.454-2.153c-.769 0-1.385-.615-1.385-1.385s.615-1.385 1.385-1.385 1.385.615 1.385 1.385-.616 1.385-1.385 1.385zm-6.5 10.107c-2.077 0-3.769-1.692-3.769-3.769s1.692-3.769 3.769-3.769h1.385v1.846h-1.385c-1.077 0-1.923.846-1.923 1.923s.846 1.923 1.923 1.923h1.385v1.846h-1.385zm15.231 0h-1.385v-1.846h1.385c1.077 0 1.923-.846 1.923-1.923s-.846-1.923-1.923-1.923h-1.385v-1.846h1.385c2.077 0 3.769 1.692 3.769 3.769s-1.692 3.769-3.769 3.769z"/>
                    </svg>
                    Pay Deposit via Venmo
                  </a>
                </div>
              <% end %>
            <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
