<% content_for :title, "Select Room - #{@trip.name}" %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-8">
    <nav class="flex" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <%= link_to root_path, class: "text-gray-400 hover:text-gray-500" do %>
            <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 10.5v6.25A2.25 2.25 0 0114.75 19h-1.5A2.25 2.25 0 0111 16.75v-4.5A.75.75 0 0111.75 12h1.5a.75.75 0 01.75.75v4.5a.75.75 0 00.75.75h1.5a.75.75 0 00.75-.75V10.5a1 1 0 01.293-.707l7-7a1 1 0 011.414 1.414L10.707 11.5H16a1 1 0 010 2H9.707l6.586 6.586a1 1 0 11-1.414 1.414l-7-7A1 1 0 018.586 13H3a1 1 0 010-2h5.586L2 4.414A1 1 0 013.414 3l7 7z" clip-rule="evenodd" />
            </svg>
            <span class="sr-only">Home</span>
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to @trip.name, trip_path(@trip), class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-500">Select Room</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="mt-4">
      <h1 class="text-3xl font-bold text-gray-900">Select Your Room</h1>
      <p class="mt-2 text-gray-600">Choose your accommodation for <%= @trip.name %>. Rooms are first-come, first-served.</p>
    </div>
  </div>

  <!-- Current Selection -->
  <% if @user_room %>
    <div class="mb-8 bg-green-50 border border-green-200 rounded-lg p-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <svg class="h-6 w-6 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <div>
            <h3 class="text-lg font-medium text-green-800">Currently Selected: <%= @user_room.name %></h3>
            <p class="text-sm text-green-700"><%= @user_room.beds_description %> • $<%= number_with_precision(@user_room.cost_per_person, precision: 2) %> per person</p>
            <% if @user_room.current_occupants.size > 1 %>
              <p class="text-xs text-green-600 mt-1">
                Roommates: <%= @user_room.current_occupants.reject { |o| o == current_user }.map(&:full_name).join(", ") %>
              </p>
            <% end %>
          </div>
        </div>
        <div>
          <p class="text-sm text-green-700">You can select a different room below</p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Room Selection -->
  <% @accommodations.each do |accommodation| %>
    <div class="mb-8 bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold text-gray-900"><%= accommodation.name %></h2>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800">
            <%= accommodation.accommodation_type.titleize %>
          </span>
        </div>
        <% if accommodation.address.present? %>
          <p class="mt-2 text-gray-600"><%= accommodation.address %></p>
        <% end %>
      </div>

      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% accommodation.rooms.each do |room| %>
            <div class="border border-gray-200 rounded-lg overflow-hidden <%= @user_room == room ? 'ring-2 ring-green-500' : 'hover:shadow-lg transition-shadow' %>">
              <!-- Room Header -->
              <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
                <div class="flex items-center justify-between">
                  <h3 class="font-semibold text-gray-900"><%= room.name %></h3>
                  <% if @user_room == room %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Selected
                    </span>
                  <% elsif !room.available? %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Full
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Available
                    </span>
                  <% end %>
                </div>
              </div>

              <!-- Room Details -->
              <div class="p-4">
                <div class="space-y-3">
                  <!-- Bed Description -->
                  <div>
                    <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Beds</dt>
                    <dd class="mt-1 text-sm text-gray-900"><%= room.beds_description %></dd>
                  </div>

                  <!-- Capacity -->
                  <div>
                    <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Capacity</dt>
                    <dd class="mt-1 text-sm text-gray-900">
                      <%= room.capacity %> person<%= room.capacity == 1 ? '' : 's' %>
                      <span class="text-gray-500">
                        (<%= room.available_spots %> available)
                      </span>
                    </dd>
                  </div>

                  <!-- Current Occupants -->
                  <% if room.current_occupants.any? %>
                    <div>
                      <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Current Occupants</dt>
                      <dd class="mt-1 text-sm">
                        <% room.current_occupants.each do |occupant| %>
                          <div class="flex items-center mt-1">
                            <svg class="h-4 w-4 text-gray-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                            </svg>
                            <span class="text-gray-700"><%= occupant.full_name %></span>
                          </div>
                        <% end %>
                      </dd>
                    </div>
                  <% end %>

                  <!-- Room Type -->
                  <div>
                    <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Type</dt>
                    <dd class="mt-1">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium
                        <%= room.room_type == 'private' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                        <%= room.room_type.titleize %>
                      </span>
                    </dd>
                  </div>

                  <!-- Cost -->
                  <div>
                    <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Cost per Person</dt>
                    <dd class="mt-1">
                      <span class="text-2xl font-bold text-gray-900">$<%= number_with_precision(room.cost_per_person, precision: 2) %></span>
                    </dd>
                  </div>
                </div>

                <!-- Action Button -->
                <div class="mt-6">
                  <% if @user_room == room %>
                    <button disabled class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 cursor-not-allowed">
                      <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      Currently Selected
                    </button>
                  <% elsif !room.available? %>
                    <button disabled class="w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
                      <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                      </svg>
                      Room Full
                    </button>
                  <% else %>
                    <%= form_with url: select_room_trip_path(@trip), method: :post, local: true do |form| %>
                      <%= form.hidden_field :room_id, value: room.id %>
                      <% if @user_room %>
                        <%= form.submit "Change to This Room",
                            class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-150 ease-in-out",
                            data: { confirm: "Are you sure you want to change from #{@user_room.name} to #{room.name}?" } %>
                      <% else %>
                        <%= form.submit "Select This Room",
                            class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition duration-150 ease-in-out",
                            data: { confirm: "Are you sure you want to select this room?" } %>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Help Text -->
  <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-6">
    <div class="flex">
      <svg class="h-5 w-5 text-blue-400 mt-0.5 mr-3" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
      </svg>
      <div>
        <h3 class="text-sm font-medium text-blue-800">Room Selection Tips</h3>
        <div class="mt-2 text-sm text-blue-700">
          <ul class="list-disc pl-5 space-y-1">
            <li>Rooms are assigned on a first-come, first-served basis</li>
            <li>Private rooms have a 40% surcharge for added privacy</li>
            <li>Bunk rooms offer a 20% discount but have shared space</li>
            <li>You can change your selection until the room becomes full</li>
            <li>Contact an admin if you have specific room requirements</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>