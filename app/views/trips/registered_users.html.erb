<% content_for :title, "Registered Users - #{@trip.name}" %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-8">
    <nav class="flex mb-4" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <%= link_to root_path, class: "text-gray-400 hover:text-gray-500" do %>
            <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 10.5v6.25A2.25 2.25 0 0114.75 19h-1.5A2.25 2.25 0 0111 16.75v-4.5A.75.75 0 0111.75 12h1.5a.75.75 0 01.75.75v4.5a.75.75 0 00.75.75h1.5a.75.75 0 00.75-.75V10.5a1 1 0 01.293-.707l7-7a1 1 0 011.414 1.414L10.707 11.5H16a1 1 0 010 2H9.707l6.586 6.586a1 1 0 11-1.414 1.414l-7-7A1 1 0 018.586 13H3a1 1 0 010-2h5.586L2 4.414A1 1 0 013.414 3l7 7z" clip-rule="evenodd" />
            </svg>
            <span class="sr-only">Home</span>
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <%= link_to @trip.name, @trip, class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-500">Registered Users</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Registered Users</h1>
        <p class="mt-2 text-gray-600"><%= pluralize(@registered_users.count, 'person') %> registered for <%= @trip.name %></p>
      </div>
      <%= link_to "Back to Trip", @trip,
          class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
    </div>
  </div>

  <!-- Registered Users List -->
  <div class="bg-white shadow-lg rounded-lg border border-gray-200 overflow-hidden">
    <% if @registered_users.any? %>
      <!-- Desktop Table View -->
      <div class="hidden md:block">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Name
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Handicap
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Room Assignment
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Email
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @registered_users.each do |data| %>
              <% user = data[:user] %>
              <% room = data[:room] %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="h-10 w-10 flex-shrink-0">
                      <% if user.avatar.attached? %>
                        <%= image_tag user.avatar.variant(resize_to_fill: [40, 40]),
                            class: "h-10 w-10 rounded-full object-cover" %>
                      <% else %>
                        <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center">
                          <svg class="h-6 w-6 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                          </svg>
                        </div>
                      <% end %>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900"><%= user.full_name %></div>
                      <div class="text-sm text-gray-500"><%= user.email %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900">
                    <%= user.handicap.present? ? user.handicap : "Not set" %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if room %>
                    <div class="text-sm text-gray-900"><%= room.name %></div>
                    <div class="text-xs text-gray-500"><%= room.accommodation.name %></div>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      No room selected
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= user.email %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Mobile Card View -->
      <div class="md:hidden">
        <div class="divide-y divide-gray-200">
          <% @registered_users.each do |data| %>
            <% user = data[:user] %>
            <% room = data[:room] %>
            <div class="p-6">
              <div class="flex items-center space-x-4">
                <div class="h-12 w-12 flex-shrink-0">
                  <% if user.avatar.attached? %>
                    <%= image_tag user.avatar.variant(resize_to_fill: [48, 48]),
                        class: "h-12 w-12 rounded-full object-cover" %>
                  <% else %>
                    <div class="h-12 w-12 rounded-full bg-gray-300 flex items-center justify-center">
                      <svg class="h-7 w-7 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                      </svg>
                    </div>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-lg font-medium text-gray-900"><%= user.full_name %></div>
                  <div class="text-sm text-gray-500"><%= user.email %></div>
                </div>
              </div>

              <div class="mt-4">
                <div>
                  <span class="font-medium text-gray-500">Handicap:</span>
                  <span class="ml-2 text-gray-900">
                    <%= user.handicap.present? ? user.handicap : "Not set" %>
                  </span>
                </div>
              </div>

              <div class="mt-4">
                <span class="font-medium text-gray-500">Room:</span>
                <div class="mt-1">
                  <% if room %>
                    <div class="text-gray-900"><%= room.name %></div>
                    <div class="text-xs text-gray-500"><%= room.accommodation.name %></div>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      No room selected
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No registered users</h3>
        <p class="mt-1 text-sm text-gray-500">No one has registered for this trip yet.</p>
      </div>
    <% end %>
  </div>
</div>