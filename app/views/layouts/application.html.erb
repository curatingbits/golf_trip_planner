<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Okie Cup" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Heroicons for modern icons -->
    <script src="https://unpkg.com/heroicons@2.0.18/24/outline/index.js" type="module"></script>
    <script src="https://unpkg.com/heroicons@2.0.18/24/solid/index.js" type="module"></script>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      function toggleProfileMenu() {
        const menu = document.getElementById('profile-menu');
        const button = document.getElementById('user-menu-button');

        if (menu.classList.contains('hidden')) {
          menu.classList.remove('hidden');
          button.setAttribute('aria-expanded', 'true');
        } else {
          menu.classList.add('hidden');
          button.setAttribute('aria-expanded', 'false');
        }
      }

      function toggleMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const button = document.getElementById('mobile-menu-button');

        if (menu.classList.contains('hidden')) {
          menu.classList.remove('hidden');
          button.setAttribute('aria-expanded', 'true');
        } else {
          menu.classList.add('hidden');
          button.setAttribute('aria-expanded', 'false');
        }
      }

      // Close dropdowns when clicking outside
      document.addEventListener('click', function(event) {
        const profileMenu = document.getElementById('profile-menu');
        const profileButton = document.getElementById('user-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileButton = document.getElementById('mobile-menu-button');

        if (profileMenu && profileButton && !profileButton.contains(event.target) && !profileMenu.contains(event.target)) {
          profileMenu.classList.add('hidden');
          profileButton.setAttribute('aria-expanded', 'false');
        }

        if (mobileMenu && mobileButton && !mobileButton.contains(event.target) && !mobileMenu.contains(event.target)) {
          mobileMenu.classList.add('hidden');
          mobileButton.setAttribute('aria-expanded', 'false');
        }
      });
    </script>
  </head>

  <body class="h-full">
    <div class="min-h-full">
      <% if current_user %>
        <!-- Navigation -->
        <nav class="bg-white shadow-lg border-b border-gray-200">
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-16 justify-between">
              <div class="flex">
                <div class="flex flex-shrink-0 items-center">
                  <%= link_to root_path, class: "flex items-center" do %>
                    <svg class="h-8 w-8 mr-2" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <!-- Trophy cup -->
                      <path d="M7 3h10c.3 0 .5.2.5.5L16 13c-.2 1.8-1.6 3.2-3.4 3.5H11.4C9.6 16.2 8.2 14.8 8 13L6.5 3.5C6.5 3.2 6.7 3 7 3z" fill="url(#navTrophyGrad)" stroke="#b8860b" stroke-width="0.5"/>
                      <!-- Rim -->
                      <rect x="6.5" y="2.5" width="11" height="1.5" rx="0.75" fill="#ffeB3b"/>
                      <!-- Left handle -->
                      <path d="M7 5.5C5 5.5 3.8 6.5 3.8 8.2c0 1.7 1.2 2.7 3.2 2.7" stroke="#daa520" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                      <!-- Right handle -->
                      <path d="M17 5.5c2 0 3.2 1 3.2 2.7 0 1.7-1.2 2.7-3.2 2.7" stroke="#daa520" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                      <!-- Stem -->
                      <rect x="10.8" y="16.2" width="2.4" height="3" rx="0.5" fill="#daa520"/>
                      <!-- Base -->
                      <rect x="8" y="19" width="8" height="1.4" rx="0.7" fill="#daa520" stroke="#b8860b" stroke-width="0.3"/>
                      <rect x="8.8" y="20.2" width="6.4" height="1" rx="0.5" fill="#b8860b"/>
                      <!-- Golf ball -->
                      <circle cx="12" cy="9.5" r="2.8" fill="#f5f5f0" stroke="#ccc" stroke-width="0.4"/>
                      <circle cx="11.2" cy="8.6" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="12" cy="8.3" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="12.8" cy="8.6" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="11.2" cy="9.5" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="12" cy="9.5" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="12.8" cy="9.5" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="11.2" cy="10.4" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="12" cy="10.7" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <circle cx="12.8" cy="10.4" r="0.5" fill="none" stroke="#ddd" stroke-width="0.3"/>
                      <!-- Star -->
                      <polygon points="12,5.5 12.4,6.5 13.4,6.5 12.6,7.1 12.9,8.1 12,7.5 11.1,8.1 11.4,7.1 10.6,6.5 11.6,6.5" fill="#fff8dc" opacity="0.7"/>
                      <defs>
                        <linearGradient id="navTrophyGrad" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stop-color="#ffd700"/>
                          <stop offset="100%" stop-color="#b8860b"/>
                        </linearGradient>
                      </defs>
                    </svg>
                    <span class="text-xl font-bold text-gray-900">Okie Cup</span>
                  <% end %>
                </div>
                <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
                  <%= link_to "Dashboard", root_path, class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>
                  <% if current_user.admin? %>
                    <%= link_to "Admin", admin_root_path, class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>
                  <% end %>
                </div>
              </div>

              <!-- Desktop navigation -->
              <div class="hidden sm:ml-6 sm:flex sm:items-center">
                <div class="relative ml-3">
                  <div class="flex items-center space-x-4">
                    <span class="text-sm text-gray-700">Welcome, <%= current_user.first_name %>!</span>

                    <!-- Profile dropdown -->
                    <div class="relative">
                      <button type="button" class="flex rounded-full bg-white text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" id="user-menu-button" aria-expanded="false" aria-haspopup="true" onclick="toggleProfileMenu()">
                        <span class="sr-only">Open user menu</span>
                        <img class="h-8 w-8 rounded-full object-cover" src="<%= current_user.avatar_url(size: 32) %>" alt="<%= current_user.full_name %>">
                      </button>

                      <div class="absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none hidden" role="menu" aria-orientation="vertical" aria-labelledby="user-menu-button" id="profile-menu" tabindex="-1">
                        <%= link_to "View Profile", profile_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", role: "menuitem" %>
                        <%= link_to "Edit Profile", edit_profile_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", role: "menuitem" %>
                        <%= link_to "Change Password", change_password_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", role: "menuitem" %>
                        <hr class="my-1">
                        <%= link_to "Logout", logout_path,
                            class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100",
                            role: "menuitem",
                            data: { "turbo-method": "delete", confirm: "Are you sure you want to logout?" } %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Mobile menu button -->
              <div class="flex items-center sm:hidden">
                <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-green-500" id="mobile-menu-button" aria-expanded="false" onclick="toggleMobileMenu()">
                  <span class="sr-only">Open main menu</span>
                  <svg class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                  </svg>
                </button>
              </div>
            </div>

            <!-- Mobile menu -->
            <div class="sm:hidden hidden" id="mobile-menu">
              <div class="pt-2 pb-3 space-y-1">
                <%= link_to "Dashboard", root_path, class: "border-transparent text-gray-600 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-800 block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>
                <% if current_user.admin? %>
                  <%= link_to "Admin", admin_root_path, class: "border-transparent text-gray-600 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-800 block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>
                <% end %>
              </div>
              <div class="pt-4 pb-3 border-t border-gray-200">
                <div class="flex items-center px-4">
                  <div class="flex-shrink-0">
                    <img class="h-10 w-10 rounded-full object-cover" src="<%= current_user.avatar_url(size: 40) %>" alt="<%= current_user.full_name %>">
                  </div>
                  <div class="ml-3">
                    <div class="text-base font-medium text-gray-800"><%= current_user.full_name %></div>
                    <div class="text-sm font-medium text-gray-500"><%= current_user.email %></div>
                  </div>
                </div>
                <div class="mt-3 space-y-1">
                  <%= link_to "View Profile", profile_path, class: "block px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100" %>
                  <%= link_to "Edit Profile", edit_profile_path, class: "block px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100" %>
                  <%= link_to "Change Password", change_password_path, class: "block px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100" %>
                  <%= link_to "Logout", logout_path,
                      class: "block px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100",
                      data: { "turbo-method": "delete", confirm: "Are you sure you want to logout?" } %>
                </div>
              </div>
            </div>
          </div>
        </nav>
      <% end %>

      <!-- Flash messages -->
      <% if notice %>
        <div class="bg-green-50 border border-green-200 rounded-md p-4 mx-auto max-w-7xl mt-4">
          <div class="flex">
            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div class="ml-3">
              <p class="text-sm text-green-800"><%= notice %></p>
            </div>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4 mx-auto max-w-7xl mt-4">
          <div class="flex">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            <div class="ml-3">
              <p class="text-sm text-red-800"><%= alert %></p>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Page content -->
      <main class="<%= current_user ? 'py-8' : 'py-12' %>">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
